{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": false,
    "trailingSlash": false,
    "redirects": [
      { "source": "/blog/flu-vaccine-family",   "destination": "https://emco.lumiaeo.com/blog/sangbong-peds-vaccination-flu-family-pack-amco",       "type": 301 },
      { "source": "/blog/post-vaccine-fever",   "destination": "https://emco.lumiaeo.com/blog/sangbong-peds-vaccination-after-shot-symptoms-amco",  "type": 301 },
      { "source": "/blog/flu-rapid-test",       "destination": "https://emco.lumiaeo.com/blog/sangbong-peds-cold-flu-rapid-test-15min-amco",       "type": 301 },
      { "source": "/blog/well-child-checkup",   "destination": "https://emco.lumiaeo.com/blog/sangbong-peds-well-child-exam-compare-friendly-amco", "type": 301 },
      { "source": "/blog/growth-curve-tips",    "destination": "https://emco.lumiaeo.com/blog/sangbong-peds-well-child-exam-growth-curve-tips-amco", "type": 301 },
      { "source": "/blog/cold-flu-symptoms",    "destination": "https://emco.lumiaeo.com/blog/sangbong-peds-cold-flu-symptoms-amco",                "type": 301 },
      { "source": "/blog/burn-first-aid",       "destination": "https://emcokids.co.kr/#블로그", "type": 301 },
      { "source": "/blog/burn-home-prevention", "destination": "https://emcokids.co.kr/#블로그", "type": 301 },
      { "source": "/blog/clinic-vs-er",         "destination": "https://emcokids.co.kr/#블로그", "type": 301 },
      { "source": "/blog/burn-degree-guide",    "destination": "https://emcokids.co.kr/#블로그", "type": 301 },
      { "source": "/blog",                      "destination": "https://emco.lumiaeo.com/blog", "type": 301 }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "emco-chatbot-api",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/console-**",
        "headers": [
          { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
          { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, private" }
        ]
      },
      {
        "source": "**/*.@(png|jpg|webp|woff2|svg)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
        ]
      },
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
        ]
      },
      {
        "source": "/sitemap.xml",
        "headers": [
          { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
          { "key": "Cache-Control", "value": "public, max-age=3600" }
        ]
      },
      {
        "source": "/feed.xml",
        "headers": [
          { "key": "Content-Type", "value": "application/rss+xml; charset=utf-8" },
          { "key": "Cache-Control", "value": "public, max-age=3600" }
        ]
      },
      {
        "source": "/robots.txt",
        "headers": [
          { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
          { "key": "Cache-Control", "value": "public, max-age=3600" }
        ]
      }
    ]
  }
}
